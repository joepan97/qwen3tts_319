#!/bin/zsh
set -euo pipefail

BASE_URL="${QWEN_TTS_API_URL:-http://127.0.0.1:7861}"
TEXT="${*:-}"
if [[ -z "$TEXT" ]]; then
  TEXT=$(cat)
fi

export BASE_URL TEXT
python3 - <<'PY'
import json
import os
import urllib.request

base = os.environ['BASE_URL']
text = os.environ['TEXT']
req = urllib.request.Request(
    base + '/synthesize',
    data=json.dumps({
        'text': text,
        'speaker': 'serena',
        'language': 'Chinese',
        'preset': 'balanced',
        'export_ogg': True,
        'export_mp3': True,
        'auto_t2s': True,
        'speed': 1.0,
    }).encode('utf-8'),
    headers={'Content-Type': 'application/json'},
)
with urllib.request.urlopen(req, timeout=600) as r:
    print(r.read().decode('utf-8'))
PY
