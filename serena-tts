#!/bin/zsh
set -euo pipefail

BASE_DIR="/Users/joepan/.openclaw/workspace/qwen3-tts"
OUT_DIR="$BASE_DIR/out"
STAMP=$(date +%Y%m%d-%H%M%S)
WAV_OUT="$OUT_DIR/serena-$STAMP.wav"
OGG_OUT="$OUT_DIR/serena-$STAMP.ogg"

mkdir -p "$OUT_DIR"
cd "$BASE_DIR"
source .venv/bin/activate
export PATH="/opt/homebrew/bin:$PATH"

TEXT="${*:-}"
if [[ -z "$TEXT" ]]; then
  TEXT=$(cat)
fi

python serena_tts.py -o "$WAV_OUT" "$TEXT"
/opt/homebrew/bin/ffmpeg -y -i "$WAV_OUT" -c:a libopus -b:a 48k "$OGG_OUT" >/dev/null 2>&1

echo "WAV=$WAV_OUT"
echo "OGG=$OGG_OUT"
